# ============================================================
# Configuración de red del laboratorio — PLANTILLA
#
# Copiar este archivo a `infra/red.local.env` (gitignored) y ajustar
# los valores si tu topología difiere de la recomendada. El archivo
# `red.local.env` es propio de cada máquina/integrante: nunca se
# commitea (ver .gitignore).
#
# Topología recomendada (ver docs/topologia-red.md): todo corre en la
# misma PC, con una red Host-Only de VirtualBox 192.168.56.0/24. La PC
# Windows queda en 192.168.56.1 automáticamente.
#
#   pfSense (LAN)  -> 192.168.56.2   (estático)
#   AD DC (DC01)   -> 192.168.56.10  (estático)
#   SQL Server     -> 192.168.56.20  (estático)
#   Minikube       -> 192.168.56.30  (estático; --driver=docker
#                      --ports=30080:30080/tcp publica el NodePort del
#                      frontend directo en esta IP)
# ============================================================

# IP de la interfaz LAN de pfSense (también usada por los scripts de
# pfsense/scripts/ para SSH + pfSsh.php playback).
PFSENSE_LAN_IP=192.168.56.2

# IP del Domain Controller (AD DS + DNS + DHCP, DC01-ITU).
DC_IP=192.168.56.10

# IP de la VM de SQL Server 2022.
# Si se deja vacío, infra/scripts/detectar-red.* intenta resolverla
# por DNS contra el DC (nslookup sqlserver.itu.local ${DC_IP}) antes
# de usar este valor como fallback.
SQLSERVER_IP=192.168.56.20

# Red /24 del laboratorio local (WAN de pfSense y red de gestión).
# Se usa como CIDR completo (incluye la máscara).
IP_RED_PROF=192.168.56.0/24

# IP estática del host de Minikube, igual que las demás VMs del
# laboratorio. minikube corre con --driver=docker
# --ports=30080:30080/tcp, que publica el NodePort 30080 del frontend
# directo en esta IP (minikube ip por sí solo devuelve la IP interna
# del bridge de Docker, no ruteable desde el resto de la red).
MINIKUBE_IP=192.168.56.30

# ----- Secretos para automatización de pfSense (pfsense/scripts/) -----
# Definir SOLO en infra/red.local.env (nunca en este archivo de
# ejemplo ni en ningún archivo commiteado).
#
# Usuario SSH de pfSense (default si se omite: admin).
# PFSENSE_SSH_USER=admin
#
# Password de la cuenta de servicio "pfsense_bind" en AD, usada por
# pfsense/scripts/auth-server-ad.php para el bind LDAP (ver
# active-directory/README.md).
# PFSENSE_BIND_PASSWORD=
