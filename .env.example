# ============================================================
# Configuración del back-end de inventario (ITU)
# Copiar este archivo como .env y completar con valores reales.
# NUNCA subir el .env real al repositorio.
# ============================================================

# ----- App -----
APP_NAME=Inventario ITU
APP_ENV=local            # local | docker | k8s
DEBUG=true

# ----- Seguridad / JWT -----
# Generar uno nuevo con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambiar_esta_clave_por_una_aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ----- SQL Server (ubicaciones) -----
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DB=inventario_ubicaciones
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=TuPassw0rdFuerte!
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# ----- MongoDB (componentes) -----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=inventario_componentes
MONGO_USER=admin
MONGO_PASSWORD=TuPassw0rdMongo!

# ----- LDAP / Active Directory -----
LDAP_HOST=localhost
LDAP_PORT=389
LDAP_BASE_DN=dc=itu,dc=edu,dc=ar
LDAP_USER_DN_TEMPLATE=uid={username},ou=usuarios,dc=itu,dc=edu,dc=ar
LDAP_USE_SSL=false